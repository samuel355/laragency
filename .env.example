# --- PRODUCTION CHECKLIST ---
# Before deploying, at minimum: APP_ENV=production, APP_DEBUG=false, set a real
# APP_URL (https://), point DB_* at a real managed Postgres (not a laptop), set a
# real MAIL_MAILER (not "log"), fill in PAYSTACK_*/ARKESEL_*/R2_* live keys, and set
# SESSION_SECURE_COOKIE=true. Run `php artisan config:cache route:cache view:cache`
# after deploy, and run a queue worker (QUEUE_CONNECTION=database) under a process
# supervisor since jobs won't process themselves.
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Production / hosted database:
# Set DB_CONNECTION=pgsql and provide DATABASE_URL or DB_URL from your managed Postgres provider.
# Do not use 127.0.0.1 in production unless the database is running on the same server/container.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# Supabase PostgreSQL example:
# DB_CONNECTION=pgsql
# DB_HOST=aws-0-eu-west-1.pooler.supabase.com
# DB_PORT=6543
# DB_DATABASE=postgres
# DB_USERNAME=postgres.fsbgpvyahsagvafxkbag
# DB_PASSWORD=
# DB_SSLMODE=require
# DB_EMULATE_PREPARES=true




SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set true in production (requires HTTPS, which APP_ENV=production enforces app-side)
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# "log" writes emails to the log file instead of sending them — fine for local
# dev, but contact/site-visit/mortgage notifications will silently go nowhere
# until this is a real transactional mailer (ses, postmark, smtp, etc.) in prod.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 (S3-compatible) — listing photo storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=agency-listings
R2_PUBLIC_URL=

VITE_APP_NAME="${APP_NAME}"

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co

ARKESEL_API_KEY=
ARKESEL_SENDER=Rentstate
ARKESEL_SMS_ENDPOINT=https://sms.arkesel.com/api/v2/sms/send

GOOGLE_API_KEY=

ADMIN_NAME="BlueGate Admin"
ADMIN_EMAIL=admin@bluegaterealty.test
ADMIN_PASSWORD=password
